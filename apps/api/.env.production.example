# Render → shari-estate-api → Environment
# Or copy from render.yaml and fill sync: false values manually.

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=3001
CORS_ORIGIN=https://YOUR-APP.vercel.app
WEB_URL=https://YOUR-APP.vercel.app
PUBLIC_URL=https://YOUR-API-SERVICE.onrender.com

UPLOAD_DIR=./uploads
DISABLE_SAVED_SEARCH_CRON=true
RUN_SEED=false

# Optional — leave empty on free tier
REDIS_URL=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=ShariEstate <onboarding@resend.dev>
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FEATURED_PRICE_ID=
