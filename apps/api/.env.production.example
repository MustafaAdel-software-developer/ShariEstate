# Use DIRECT connection (no -pooler) for prisma db push / seed
# In Neon Connect: turn OFF "Connection pooling" to copy the direct URL
DATABASE_URL="postgresql://neondb_owner:REPLACE_WITH_YOUR_PASSWORD@ep-long-sky-atff8495.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=3001
CORS_ORIGIN=https://YOUR-APP.vercel.app
WEB_URL=https://YOUR-APP.vercel.app
PUBLIC_URL=https://YOUR-API-SERVICE.onrender.com

UPLOAD_DIR=./uploads
DISABLE_SAVED_SEARCH_CRON=true
RUN_SEED=false

