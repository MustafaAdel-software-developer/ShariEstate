generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  agent
  seller
  admin
}

enum ListingType {
  sale
  rent
}

enum PropertyType {
  house
  condo
  townhouse
  land
  commercial
}

enum ListingStatus {
  draft
  pending
  active
  sold
  rented
  off_market
}

enum ListingSource {
  manual
  mls
}

enum InquiryStatus {
  new
  contacted
  closed
}

enum TourStatus {
  pending
  confirmed
  cancelled
  completed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(buyer)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agentProfile  AgentProfile?
  favorites     Favorite[]
  savedSearches SavedSearch[]
  inquiries     Inquiry[]
  tourRequests  TourRequest[]
  sentMessages  Message[]     @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  refreshTokens RefreshToken[]
  listingViews  ListingView[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model State {
  id             String  @id @default(uuid())
  name           String
  slug           String  @unique
  abbreviation   String  @unique @db.VarChar(2)
  heroTitle      String? @map("hero_title")
  heroSubtitle   String? @map("hero_subtitle")
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  enabled        Boolean @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cities   City[]
  listings Listing[]

  @@map("states")
}

model City {
  id             String  @id @default(uuid())
  name           String
  slug           String
  stateId        String  @map("state_id")
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  state         State          @relation(fields: [stateId], references: [id], onDelete: Cascade)
  neighborhoods Neighborhood[]
  listings      Listing[]

  @@unique([stateId, slug])
  @@map("cities")
}

model Neighborhood {
  id        String   @id @default(uuid())
  name      String
  slug      String
  cityId    String   @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city     City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([cityId, slug])
  @@map("neighborhoods")
}

model Brokerage {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  website   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agents AgentProfile[]

  @@map("brokerages")
}

model AgentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  slug          String   @unique
  bio           String?
  phone         String?
  licenseNumber String?  @map("license_number")
  photoUrl      String?  @map("photo_url")
  brokerageId   String?  @map("brokerage_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  brokerage Brokerage? @relation(fields: [brokerageId], references: [id])
  listings  Listing[]

  @@map("agent_profiles")
}

model Listing {
  id             String        @id @default(uuid())
  title          String
  description    String
  listingType    ListingType   @map("listing_type")
  propertyType   PropertyType  @map("property_type")
  status         ListingStatus @default(draft)
  source         ListingSource @default(manual)
  price          Decimal       @db.Decimal(12, 2)
  beds           Int           @default(0)
  baths          Decimal       @default(0) @db.Decimal(3, 1)
  sqft           Int?
  yearBuilt      Int?          @map("year_built")
  address        String
  zip            String
  lat            Float?
  lng            Float?
  isFeatured     Boolean       @default(false) @map("is_featured")
  isPremium      Boolean       @default(false) @map("is_premium")
  viewCount      Int           @default(0) @map("view_count")
  saveCount      Int           @default(0) @map("save_count")
  stateId        String        @map("state_id")
  cityId         String        @map("city_id")
  neighborhoodId String?       @map("neighborhood_id")
  agentId        String?       @map("agent_id")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  state        State          @relation(fields: [stateId], references: [id])
  city         City           @relation(fields: [cityId], references: [id])
  neighborhood Neighborhood?  @relation(fields: [neighborhoodId], references: [id])
  agent        AgentProfile?  @relation(fields: [agentId], references: [id])
  images       ListingImage[]
  features     ListingFeature[]
  favorites    Favorite[]
  inquiries    Inquiry[]
  tourRequests TourRequest[]
  messages     Message[]
  priceHistory PriceHistory[]
  openHouses   OpenHouse[]
  views        ListingView[]

  @@index([stateId, status, listingType, price])
  @@index([cityId, status])
  @@index([lat, lng])
  @@map("listings")
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String   @map("listing_id")
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  isCover   Boolean  @default(false) @map("is_cover")
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model ListingFeature {
  id        String @id @default(uuid())
  listingId String @map("listing_id")
  name      String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_features")
}

model PriceHistory {
  id        String        @id @default(uuid())
  listingId String        @map("listing_id")
  price     Decimal       @db.Decimal(12, 2)
  status    ListingStatus
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

model OpenHouse {
  id        String   @id @default(uuid())
  listingId String   @map("listing_id")
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("open_houses")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}

model SavedSearch {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  filters     Json
  emailAlerts Boolean  @default(true) @map("email_alerts")
  lastNotifiedAt DateTime? @map("last_notified_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

model Inquiry {
  id        String        @id @default(uuid())
  listingId String        @map("listing_id")
  userId    String?       @map("user_id")
  name      String
  email     String
  phone     String?
  message   String
  status    InquiryStatus @default(new)
  createdAt DateTime      @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("inquiries")
}

model TourRequest {
  id            String     @id @default(uuid())
  listingId     String     @map("listing_id")
  userId        String?    @map("user_id")
  name          String
  email         String
  phone         String?
  preferredDate DateTime   @map("preferred_date")
  preferredTime String     @map("preferred_time")
  message       String?
  status        TourStatus @default(pending)
  createdAt     DateTime   @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("tour_requests")
}

model Message {
  id          String    @id @default(uuid())
  listingId   String    @map("listing_id")
  senderId    String    @map("sender_id")
  recipientId String    @map("recipient_id")
  body        String
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender    User    @relation("SentMessages", fields: [senderId], references: [id])
  recipient User    @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([listingId, senderId, recipientId])
  @@map("messages")
}

model ListingView {
  id        String   @id @default(uuid())
  listingId String   @map("listing_id")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("listing_views")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
